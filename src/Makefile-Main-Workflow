# Compiler and flags
CC = gcc
CFLAGS = -Wall -Wextra -g -D_DEBUG   # Enable warnings and debugging symbols
#LDFLAGS = -ldl              # Link dynamic library functions if needed

# Source files
SRCS = Main.Kobi.Workflow2.c aes.c Base64.c EncryptionToolsApi.c Hmac.c HighLevED.c Global2.c SHA256.c Functions3.c Pstr.c UberHighLevED.c ProcMSG.c API.c CryptoRng.c HmacSha256.c
#SRCS = Main.Kobi.Workflow2.c aes.c Base64.c EncryptionToolsApi.c Hmac.c HighLevED.c Global2.c SHA256.c Pstr.c UberHighLevED.c  # List all source files here

# Object files
OBJS = $(SRCS:.c=.o)

# Executable name
EXEC = MainWF-SRC

# Build the executable
all: $(EXEC)

$(EXEC): $(OBJS)
	$(CC) $(CFLAGS) $(OBJS) -o $(EXEC) $(LDFLAGS)

# Compile source files into object files
%.o: %.c
	$(CC) $(CFLAGS) -I./include -c $< -o $@

# Clean build files
clean:
	rm -f $(OBJS) $(EXEC)
