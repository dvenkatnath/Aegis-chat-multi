{
  email {$ACME_EMAIL}
}

{$DOMAIN} {
  encode gzip zstd

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # CSP: allow scripts only from same origin (the WASM bundle is inlined via
    # SINGLE_FILE=1; no external script hosts needed).  wasm-unsafe-eval is
    # required for Emscripten WASM instantiation in all browsers.
    Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' wss: stun: turn:; img-src 'self' data:; style-src 'self' 'unsafe-inline'; frame-ancestors 'none';"
  }

  handle /api/* {
    reverse_proxy keyserver:8080
  }

  handle {
    root * /srv/dist
    try_files {path} /index.html
    file_server
  }
}
