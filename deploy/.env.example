# Copy to .env and fill in before: docker compose --env-file .env up -d

# Public domain (must point to this server's public IP)
DOMAIN=chat.example.com
ACME_EMAIL=admin@example.com

# Shared secret for coturn — must match TURN_SECRET below
# Generate: openssl rand -hex 32
TURN_SECRET=change-me-to-a-long-random-string

# Public hostname clients use to reach TURN (usually same as DOMAIN)
TURN_PUBLIC_HOST=chat.example.com

# Keyserver log signing (generate: openssl rand -hex 32)
LOG_SECRET=change-me-log-signing-secret

# CORS: MUST be set to your exact production origin — no wildcards.
# The keyserver will refuse to start in production if this is '*' or empty.
# Example: CORS_ORIGIN=https://chat.example.com
CORS_ORIGIN=https://chat.example.com

# Set to 'production' to enable startup safety checks (CORS, LOG_SECRET).
# Never leave as 'development' in a deployed environment.
NODE_ENV=production
